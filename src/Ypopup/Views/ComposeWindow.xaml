<Window x:Class="Ypopup.Views.ComposeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Ypopup - 쪽지 보내기"
        Width="460"
        Height="420"
        WindowStartupLocation="CenterScreen"
        Topmost="True">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="RecipientTextBlock"
                   Grid.Row="0"
                   FontWeight="SemiBold"
                   Margin="0,0,0,8"/>

        <TextBox x:Name="MessageTextBox"
                 Grid.Row="1"
                 AcceptsReturn="True"
                 TextWrapping="Wrap"
                 VerticalScrollBarVisibility="Auto"
                 AllowDrop="True"
                 Drop="MessageTextBox_Drop"
                 PreviewDragOver="MessageTextBox_PreviewDragOver"/>

        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    Margin="0,8,0,0">
            <Button Content="파일 첨부"
                    Click="AttachButton_Click"/>
            <TextBlock x:Name="AttachmentSummaryTextBlock"
                       VerticalAlignment="Center"
                       Margin="12,0,0,0"
                       Foreground="Gray"/>
        </StackPanel>

        <ListBox x:Name="AttachmentListBox"
                 Grid.Row="3"
                 Height="80"
                 Margin="0,8,0,0"/>

        <StackPanel Grid.Row="4"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,12,0,0">
            <Button x:Name="SendButton"
                    Content="전송"
                    Click="SendButton_Click"
                    Margin="0,0,8,0"/>
            <Button Content="닫기"
                    Click="CloseButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
