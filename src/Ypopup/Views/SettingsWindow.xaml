<Window x:Class="Ypopup.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Ypopup - 환경 설정"
        Width="480"
        Height="360"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="120"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.Column="0" Text="표시 이름" VerticalAlignment="Center"/>
        <TextBox x:Name="DisplayNameTextBox" Grid.Row="0" Grid.Column="1" Margin="0,0,0,8"/>

        <TextBlock Grid.Row="1" Grid.Column="0" Text="수신 폴더" VerticalAlignment="Center"/>
        <DockPanel Grid.Row="1" Grid.Column="1" Margin="0,0,0,8">
            <Button Content="찾기" DockPanel.Dock="Right" Click="BrowseFolderButton_Click"/>
            <TextBox x:Name="ReceiveDirectoryTextBox" Margin="0,0,8,0"/>
        </DockPanel>

        <TextBlock Grid.Row="2" Grid.Column="0" Text="TCP 포트" VerticalAlignment="Center"/>
        <TextBox x:Name="TcpPortTextBox" Grid.Row="2" Grid.Column="1" Margin="0,0,0,8"/>

        <TextBlock Grid.Row="3" Grid.Column="0" Text="탐색 포트" VerticalAlignment="Center"/>
        <TextBox x:Name="DiscoveryPortTextBox" Grid.Row="3" Grid.Column="1" Margin="0,0,0,8"/>

        <CheckBox x:Name="PlaySoundCheckBox"
                  Grid.Row="4"
                  Grid.Column="1"
                  Content="수신 시 알림음 재생"
                  Margin="0,0,0,8"/>

        <TextBlock Grid.Row="5"
                   Grid.Column="0"
                   Grid.ColumnSpan="2"
                   TextWrapping="Wrap"
                   Foreground="Gray"
                   Text="Windows 방화벽에서 Ypopup의 UDP/TCP 포트 허용이 필요할 수 있습니다. 네트워크 프로필은 '개인'으로 설정하세요."/>

        <StackPanel Grid.Row="6"
                    Grid.Column="1"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,12,0,0">
            <Button Content="저장"
                    Click="SaveButton_Click"
                    Margin="0,0,8,0"/>
            <Button Content="취소"
                    Click="CancelButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
