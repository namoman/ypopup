<Window x:Class="Ypopup.App.Views.UserListWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Y-popup - 사용자 목록"
        Width="340"
        Height="520"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanMinimize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">
    <Window.Resources>
        <Style x:Key="TitleBarButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="34"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="MinWidth" Value="30"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="IconButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="4" Padding="6">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#1EFFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="#E60F172A" CornerRadius="16" BorderBrush="#1CFFFFFF" BorderThickness="1.5">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/> <!-- Title Bar -->
                <RowDefinition Height="Auto"/> <!-- Header (Logo/Title) -->
                <RowDefinition Height="Auto"/> <!-- Search Bar -->
                <RowDefinition Height="*"/>    <!-- User List -->
                <RowDefinition Height="Auto"/> <!-- Footer Actions -->
            </Grid.RowDefinitions>

            <!-- 1. Custom Title Bar -->
            <Grid Grid.Row="0" Height="30" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0,0,0">
                    <TextBlock Text="Y-popup LAN messenger" FontSize="11" Foreground="#64748B" FontWeight="Medium"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Content="—" Foreground="#94A3B8" Click="MinimizeButton_Click" Style="{StaticResource TitleBarButtonStyle}"/>
                    <Button Content="✕" Foreground="#EF4444" Click="CloseButton_Click" Style="{StaticResource TitleBarButtonStyle}"/>
                </StackPanel>
            </Grid>

            <!-- 2. Application Header Area -->
            <Grid Grid.Row="1" Margin="16,8,16,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal">
                    <!-- Rounded Telephone Logo Icon -->
                    <Border Width="36" Height="36" Background="#EF4444" CornerRadius="10" Margin="0,0,12,0">
                        <TextBlock Text="☎" Foreground="White" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,0,0,2"/>
                    </Border>
                    <TextBlock Text="Y-popup" FontSize="22" FontWeight="Bold" Foreground="#F8FAFC" VerticalAlignment="Center"/>
                </StackPanel>

                <Button Grid.Column="1" Style="{StaticResource IconButtonStyle}" Click="SettingsButton_Click">
                    <TextBlock Text="⚙" FontSize="18" Foreground="#94A3B8"/>
                </Button>
            </Grid>

            <!-- 3. Search Bar -->
            <Grid Grid.Row="2" Margin="16,0,16,12">
                <TextBox x:Name="SearchTextBox" Padding="28,8,10,8" Background="#1E293B" Foreground="#F8FAFC" BorderThickness="0" TextChanged="SearchTextBox_TextChanged"/>
                <TextBlock IsHitTestVisible="False" Text="사용자 검색..." VerticalAlignment="Center" HorizontalAlignment="Left" Margin="30,0,0,0" Foreground="#64748B">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ElementName=SearchTextBox, Path=Text}" Value="">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
                <TextBlock Text="🔍" IsHitTestVisible="False" Foreground="#64748B" FontSize="12" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="10,0,0,0"/>
            </Grid>

            <!-- 4. User List Box -->
            <ListBox x:Name="PeerListBox"
                     Grid.Row="3"
                     Margin="16,0,16,8"
                     Background="Transparent"
                     BorderThickness="0"
                     MouseDoubleClick="PeerListBox_MouseDoubleClick">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border x:Name="ItemBorder" CornerRadius="8" Padding="8" Background="Transparent" Width="290">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- Circular Avatar -->
                                <Grid Grid.Column="0" Width="40" Height="40" Margin="0,0,12,0" VerticalAlignment="Center">
                                    <Ellipse Fill="#334155" Width="40" Height="40"/>
                                    <TextBlock Text="👤" Foreground="#94A3B8" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="18"/>
                                    <Ellipse x:Name="StatusDot" Width="10" Height="10" 
                                             Fill="#22C55E" 
                                             Stroke="#0F172A" StrokeThickness="1.5"
                                             HorizontalAlignment="Right" VerticalAlignment="Bottom"/>
                                </Grid>

                                <!-- Text Info -->
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" FontSize="13.5" Foreground="#F8FAFC"/>
                                    <TextBlock Text="{Binding Group}" FontSize="11" Foreground="#64748B" Margin="0,1,0,0"/>
                                    <TextBlock x:Name="MemoText" Text="{Binding Memo}" FontSize="11" Foreground="#38BDF8" FontStyle="Italic" Margin="0,2,0,0"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                        <DataTemplate.Triggers>
                            <DataTrigger Binding="{Binding IsAway}" Value="True">
                                <Setter TargetName="StatusDot" Property="Fill" Value="#F59E0B"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Memo}" Value="">
                                <Setter TargetName="MemoText" Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </DataTemplate.Triggers>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <!-- 5. Footer Buttons -->
            <Grid Grid.Row="4" Margin="16,8,16,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button Content="쪽지 보내기"
                        Click="SendButton_Click"
                        HorizontalAlignment="Left"
                        Width="130"/>

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Content="새로고침"
                            Click="RefreshButton_Click"
                            Margin="0,0,8,0"
                            Background="#1E293B"
                            Foreground="#F8FAFC"
                            Width="80"/>
                    <Button Content="닫기"
                            Click="CloseButton_Click"
                            Background="#1E293B"
                            Foreground="#F8FAFC"
                            Width="70"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>
