<Window x:Class="Ypopup.App.Views.ReceiveWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Y-popup - 쪽지 수신"
        Width="460"
        Height="420"
        WindowStartupLocation="CenterScreen"
        Topmost="True">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="SenderTextBlock"
                   Grid.Row="0"
                   FontWeight="SemiBold"
                   Margin="0,0,0,8"/>

        <TextBox x:Name="MessageTextBox"
                 Grid.Row="1"
                 IsReadOnly="True"
                 TextWrapping="Wrap"
                 VerticalScrollBarVisibility="Auto"/>

        <ListBox x:Name="AttachmentListBox"
                 Grid.Row="2"
                 Height="100"
                 Margin="0,8,0,0"
                 MouseDoubleClick="AttachmentListBox_MouseDoubleClick"/>

        <StackPanel Grid.Row="3"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,12,0,0">
            <Button Content="답장"
                    Click="ReplyButton_Click"
                    Margin="0,0,8,0"/>
            <Button Content="폴더 열기"
                    Click="OpenFolderButton_Click"
                    Margin="0,0,8,0"/>
            <Button Content="닫기"
                    Click="CloseButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
