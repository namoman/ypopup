<Window x:Class="Ypopup.App.Views.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:Ypopup.App"
        Title="Y-popup 정보"
        Width="360"
        Height="240"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        ShowInTaskbar="False">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="{x:Static local:AppInfo.ProductName}"
                   FontSize="18"
                   FontWeight="SemiBold"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,16"/>

        <TextBlock Grid.Row="1"
                   Text="{x:Static local:AppInfo.AboutText}"
                   TextAlignment="Center"
                   TextWrapping="Wrap"
                   VerticalAlignment="Center"/>

        <Button Grid.Row="2"
                Content="확인"
                HorizontalAlignment="Center"
                Margin="0,16,0,0"
                IsDefault="True"
                Click="OkButton_Click"/>
    </Grid>
</Window>
